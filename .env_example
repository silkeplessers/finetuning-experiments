# Copy this file to .env and fill in real values. .env is gitignored.
# Never commit real tokens to .env_example.

# Hugging Face token — only required for gated/private base models.
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Weights & Biases API key — only required when wandb.enabled=true in qlora_config.json.
WANDB_API_KEY=wandb_v1_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Azure OpenAI account base URL (note the trailing /openai/v1/).
ENDPOINT="https://<your-aoai-resource>.openai.azure.com/openai/v1/"

# Deployment used by synthetic data generation.
DEPLOYMENT="<your-chat-deployment-name>"

# Storage account + user-managed container that holds datasets and synthetic data.
STORAGE_ACCOUNT="<your-storage-account-name>"
CONTAINER_NAME="finetuning-training-data"

# Judge deployments for dual-judge LLM-as-judge evaluation.
JUDGE_LLM_1="<judge-1-deployment-name>"
JUDGE_LLM_2="<judge-2-deployment-name>"